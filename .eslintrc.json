{
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "node/no-unsupported-features/es-syntax": ["error", {
      "version": ">=14.17.0",
      "ignores": ["modules"]
    }],
    "node/no-missing-import": ["error", {
      "allowModules": [],
      "tryExtensions": [".js", ".json", ".node"]
    }]
  }
}
